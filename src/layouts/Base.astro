---
/**
 * Base.astro — Master layout
 * Every page passes: title, description, slug, schema (array of JSON-LD objects),
 * citationSentence, pageType ('calculator' | 'home' | 'article')
 */
import '../styles/global.css';
interface Props {
  title: string;
  description: string;
  slug: string;
  schema?: object[];
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  slug,
  schema = [],
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const siteUrl   = 'https://freemarketingcalculator.com'; // ← replace before deploy
const canonical = `${siteUrl}/${slug ? slug + '/' : ''}`;
const ogUrl     = canonical;

// Merge Organisation schema into every page's JSON-LD array
const orgSchema = {
  "@type": "Organization",
  "@id": `${siteUrl}/#org`,
  "name": "Free Marketing Calculators",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/logo.svg`
  },
  "description": "Free marketing calculators for ROI, budget, salary, conversion rate, and more.",
  "sameAs": [
    "https://www.linkedin.com/company/marketcalcs",
    "https://twitter.com/marketcalcs"
  ]
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": "Free Marketing Calculators",
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}/#org` }
};

const fullSchema = {
  "@context": "https://schema.org",
  "@graph": [orgSchema, websiteSchema, ...schema]
};

---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="Dbj3G7byAbkR1vo2xlW2YY8mhTy-BuOJ0TAEyNlIxB8" />
  <!-- Bing Webmaster Tools verification -->
  <meta name="msvalidate.01" content="B0B744590B03AB0EF8CBFEC64AEBE8AC" />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:site_name" content="Free Marketing Calculators" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(fullSchema)} />

  <!-- Inter font — self-hosted subset for performance (swap to avoid FOIT) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  />

  <!-- Global styles injected via Astro import in frontmatter -->

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- AdSense: add script here after approval -->
</head>

<body>
  <div class="page-wrap">

    <!-- ===== SITE HEADER ===== -->
    <header class="site-header" role="banner">
      <div class="container">
        <a href="/" class="site-logo" aria-label="Free Marketing Calculators home">
          <!-- Bar chart icon -->
          <svg width="28" height="28" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="flex-shrink:0">
            <rect width="64" height="64" rx="10" fill="#00C4B3"/>
            <rect x="8"  y="40" width="11" height="16" rx="2" fill="white"/>
            <rect x="23" y="28" width="11" height="28" rx="2" fill="white" opacity="0.85"/>
            <rect x="38" y="16" width="11" height="40" rx="2" fill="white"/>
            <polyline points="13,38 28.5,26 43.5,14 56,8" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
          </svg>
          <span class="logo-text">Free<span class="logo-accent">Marketing</span>Calc</span>
        </a>
        <nav aria-label="Main navigation">
          <ul class="site-nav">
            <li><a href="/marketing-roi-calculator/">ROI Calculator</a></li>
            <li><a href="/marketing-budget-calculator/">Budget</a></li>
            <li><a href="/conversion-rate-calculator/">Conversion Rate</a></li>
            <li><a href="/email-marketing-roi-calculator/">Email ROI</a></li>
            <li><a href="/marketing-salary-calculator/">Salary</a></li>
            <li><a href="/blog/">Blog</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ===== SITE FOOTER ===== -->
    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div>
          <p>
            &copy; {new Date().getFullYear()} Free Marketing Calculators &mdash;
            Free marketing calculators, no signup required.
          </p>
          <p style="margin-top: 0.5rem;">
            Formulas sourced from industry-standard definitions.
            Benchmarks compiled from public data; updated quarterly.
            Not financial advice.
          </p>
        </div>
        <nav aria-label="Footer navigation">
          <ul class="footer-links">
            <li><a href="/">All Calculators</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="/about/">About</a></li>
            <li><a href="/privacy-policy/">Privacy Policy</a></li>
            <li><a href="/sitemap-index.xml">Sitemap</a></li>
          </ul>
        </nav>
      </div>
    </footer>

  </div>
</body>
</html>
