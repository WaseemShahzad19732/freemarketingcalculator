---
import Base from '../layouts/Base.astro';
import FAQ from '../components/FAQ.astro';

const slug        = 'conversion-rate-calculator';
const title       = 'Conversion Rate Calculator — Free Marketing Tool 2026';
const description = 'Calculate marketing conversion rate, reverse-compute traffic needed for a sales goal, and benchmark against 2026 averages by channel. Free, no signup.';

const benchmarks = [
  { channel: 'Email Marketing',    cvr: '4.0%', range: '2–7%' },
  { channel: 'Organic Search',     cvr: '3.5%', range: '2–6%' },
  { channel: 'Paid Search (SEM)',  cvr: '3.2%', range: '2–5%' },
  { channel: 'Direct Traffic',     cvr: '5.0%', range: '3–8%' },
  { channel: 'Social Media',       cvr: '1.5%', range: '0.5–3%' },
  { channel: 'Referral Traffic',   cvr: '3.0%', range: '1–5%' },
  { channel: 'Display Ads',        cvr: '0.7%', range: '0.3–1%' },
];

const faqItems = [
  { q: 'How do you calculate conversion rate?', a: 'Conversion Rate = (Conversions ÷ Total Visitors) × 100. For example, 50 conversions from 2,000 visitors = 50 ÷ 2,000 × 100 = 2.5% conversion rate.' },
  { q: 'What is a good marketing conversion rate?', a: 'A good conversion rate is typically 2–5% for most marketing channels. Email marketing averages 4%, paid search 3%, social media 1–2%. Top performers achieve 10%+ by optimising landing pages and targeting.' },
  { q: 'How much traffic do I need to hit my revenue goal?', a: 'Use the reverse calculator: divide your target conversions by your conversion rate. If you need 100 sales and convert at 2%, you need 5,000 visitors (100 ÷ 0.02).' },
  { q: 'What affects conversion rate most?', a: 'Landing page clarity, page load speed, offer relevance, trust signals (reviews, security badges), and mobile optimisation. A/B testing headlines and CTAs typically yields the fastest wins.' },
  { q: 'Is this calculator free?', a: 'Yes — completely free, no signup, no email required.' },
];

const webAppSchema = {
  "@type": "WebApplication", "name": title,
  "applicationCategory": "BusinessApplication", "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "creator": { "@id": "https://freemarketingcalculator.com/#org" },
  "url": "https://freemarketingcalculator.com/conversion-rate-calculator/",
  "description": "Calculates marketing conversion rate from visits and conversions, reverse-computes traffic needed to hit a revenue goal, and benchmarks by channel.",
  "featureList": ["CVR from visits/conversions", "Reverse calculator", "2026 channel benchmarks"]
};
const faqSchema = { "@type": "FAQPage", "mainEntity": faqItems.map(i => ({ "@type": "Question", "name": i.q, "acceptedAnswer": { "@type": "Answer", "text": i.a } })) };
const breadcrumbSchema = { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freemarketingcalculator.com/" }, { "@type": "ListItem", "position": 2, "name": "Conversion Rate Calculator", "item": "https://freemarketingcalculator.com/conversion-rate-calculator/" }] };
---

<Base title={title} description={description} slug={slug} schema={[webAppSchema, faqSchema, breadcrumbSchema]}>
  <section class="page-hero" aria-labelledby="page-h1">
    <div class="container">
      <p class="eyebrow">Free Marketing Tool</p>
      <h1 id="page-h1">Conversion Rate Calculator</h1>
      <p class="citation">Calculates marketing conversion rate from visits and conversions, reverse-computes the traffic needed to hit a revenue goal, and benchmarks your rate against 2026 industry averages by channel.</p>
      <div class="meta-badges">
        <span class="badge">✓ 3 calculation modes</span>
        <span class="badge">✓ Channel benchmarks</span>
        <span class="badge">✓ No signup</span>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="calc-card">
      <div class="calc-card__header">
        <div class="calc-card__header-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 014-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
        </div>
        <div><div class="calc-card__title">Conversion Rate Calculator</div><div class="calc-card__subtitle">Choose a calculation mode below</div></div>
      </div>
      <div class="calc-card__body">
        <div class="field">
          <label>Calculation Mode</label>
          <div class="mode-toggle" role="group">
            <button type="button" class="active" id="mode-cvr">CVR from Visits</button>
            <button type="button" id="mode-reverse">Reverse: Traffic Needed</button>
            <button type="button" id="mode-revenue">Revenue from CVR</button>
          </div>
        </div>

        <div id="inputs-cvr" class="field-group">
          <div class="field"><label for="cvr-visitors">Total Visitors</label><input type="number" id="cvr-visitors" placeholder="e.g. 10000" min="0"/></div>
          <div class="field"><label for="cvr-conversions">Conversions</label><input type="number" id="cvr-conversions" placeholder="e.g. 250" min="0"/></div>
        </div>

        <div id="inputs-reverse" class="field-group" style="display:none">
          <div class="field"><label for="rev-target">Target Conversions per Month</label><input type="number" id="rev-target" placeholder="e.g. 100" min="0"/></div>
          <div class="field"><label for="rev-cvr">Your Conversion Rate (%)</label><div class="input-wrap"><input type="number" id="rev-cvr" class="has-suffix" placeholder="e.g. 2.5" min="0" max="100" step="0.1"/><span class="input-suffix">%</span></div></div>
        </div>

        <div id="inputs-revenue" class="field-group" style="display:none">
          <div class="field"><label for="rrev-visitors">Monthly Visitors</label><input type="number" id="rrev-visitors" placeholder="e.g. 5000" min="0"/></div>
          <div class="field"><label for="rrev-cvr">Conversion Rate (%)</label><div class="input-wrap"><input type="number" id="rrev-cvr" class="has-suffix" placeholder="e.g. 3" min="0" max="100" step="0.1"/><span class="input-suffix">%</span></div></div>
          <div class="field"><label for="rrev-aov">Average Order / Deal Value ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="rrev-aov" class="has-prefix" placeholder="e.g. 500" min="0"/></div></div>
        </div>

        <button class="btn-calc" id="cvr-calc-btn" type="button">Calculate</button>

        <div class="result-panel" id="cvr-result" aria-live="polite">
          <div class="result-panel__label" id="cvr-result-label">Conversion Rate</div>
          <div class="result-panel__primary" id="cvr-primary">0%</div>
          <div class="result-panel__grid">
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="cvr-stat1">—</span><span class="result-panel__stat-label" id="cvr-stat1-label">Conversions</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="cvr-stat2">—</span><span class="result-panel__stat-label" id="cvr-stat2-label">Visitors</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="cvr-stat3">—</span><span class="result-panel__stat-label" id="cvr-stat3-label">Revenue/mo</span></div>
          </div>
          <div class="result-verdict" id="cvr-verdict"></div>
        </div>
      </div>
    </div>

    <div class="definition-box">
      <div class="definition-box__label">Formula</div>
      <p><strong>Conversion Rate = (Conversions ÷ Visitors) × 100</strong><br/>
      Reverse: Visitors Needed = Target Conversions ÷ (CVR ÷ 100)<br/>
      Example: 50 sales ÷ 0.025 CVR = 2,000 visitors needed</p>
    </div>

    <section class="bench-section">
      <h2>Conversion Rate Benchmarks by Channel — 2026</h2>
      <span class="bench-date">Updated July 2026</span>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead><tr><th>Channel</th><th>Average CVR</th><th>Typical Range</th></tr></thead>
          <tbody>
            {benchmarks.map(r => (<tr><td>{r.channel}</td><td><strong>{r.cvr}</strong></td><td>{r.range}</td></tr>))}
          </tbody>
        </table>
      </div>
      <p class="bench-source">Sources: WordStream, HubSpot, Unbounce Conversion Benchmark Report 2026.</p>
    </section>

    <FAQ items={faqItems} />
  </div>
</Base>

<script>
(function(){
  'use strict';
  const modes = ['cvr','reverse','revenue'];
  const btns = { cvr: document.getElementById('mode-cvr'), reverse: document.getElementById('mode-reverse'), revenue: document.getElementById('mode-revenue') };
  const inputs = { cvr: document.getElementById('inputs-cvr'), reverse: document.getElementById('inputs-reverse'), revenue: document.getElementById('inputs-revenue') };
  const calcBtn = document.getElementById('cvr-calc-btn');
  const result = document.getElementById('cvr-result');
  const primary = document.getElementById('cvr-primary');
  const label = document.getElementById('cvr-result-label');
  const stat1 = document.getElementById('cvr-stat1'), stat1l = document.getElementById('cvr-stat1-label');
  const stat2 = document.getElementById('cvr-stat2'), stat2l = document.getElementById('cvr-stat2-label');
  const stat3 = document.getElementById('cvr-stat3'), stat3l = document.getElementById('cvr-stat3-label');
  const verdict = document.getElementById('cvr-verdict');
  if (!calcBtn) return;

  let mode = 'cvr';

  Object.entries(btns).forEach(([m, btn]) => {
    btn.addEventListener('click', () => {
      mode = m;
      Object.values(btns).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      Object.values(inputs).forEach(i => i.style.display = 'none');
      inputs[m].style.display = 'grid';
    });
  });

  function fmt(n) { return n >= 1000000 ? '$' + (n/1000000).toFixed(2) + 'M' : n >= 1000 ? '$' + Math.round(n).toLocaleString() : '$' + Math.round(n).toLocaleString(); }
  function getVerdict(cvr) {
    if (cvr < 1) return '⚠️ Below average — focus on landing page optimisation';
    if (cvr < 3) return '🟡 Average range — room to improve with A/B testing';
    if (cvr < 6) return '✅ Good — above average for most channels';
    return '🚀 Excellent — top-quartile performance';
  }

  calcBtn.addEventListener('click', () => {
    if (mode === 'cvr') {
      const v = parseFloat(document.getElementById('cvr-visitors').value);
      const c = parseFloat(document.getElementById('cvr-conversions').value);
      if (!v || !c) return;
      const cvr = (c / v) * 100;
      label.textContent = 'Conversion Rate';
      primary.textContent = cvr.toFixed(2) + '%';
      stat1.textContent = c.toLocaleString(); stat1l.textContent = 'Conversions';
      stat2.textContent = v.toLocaleString(); stat2l.textContent = 'Visitors';
      stat3.textContent = '—'; stat3l.textContent = '';
      verdict.textContent = getVerdict(cvr);
    } else if (mode === 'reverse') {
      const t = parseFloat(document.getElementById('rev-target').value);
      const r = parseFloat(document.getElementById('rev-cvr').value);
      if (!t || !r) return;
      const needed = Math.ceil(t / (r / 100));
      label.textContent = 'Monthly Visitors Needed';
      primary.textContent = needed.toLocaleString();
      stat1.textContent = t.toLocaleString(); stat1l.textContent = 'Target conversions';
      stat2.textContent = r + '%'; stat2l.textContent = 'Your CVR';
      stat3.textContent = '—'; stat3l.textContent = '';
      verdict.textContent = '📊 You need ' + needed.toLocaleString() + ' visitors/month to hit ' + t + ' conversions at ' + r + '% CVR';
    } else {
      const v = parseFloat(document.getElementById('rrev-visitors').value);
      const r = parseFloat(document.getElementById('rrev-cvr').value);
      const aov = parseFloat(document.getElementById('rrev-aov').value);
      if (!v || !r || !aov) return;
      const convs = Math.round(v * (r / 100));
      const revenue = convs * aov;
      label.textContent = 'Estimated Monthly Revenue';
      primary.textContent = fmt(revenue);
      stat1.textContent = convs.toLocaleString(); stat1l.textContent = 'Conversions/mo';
      stat2.textContent = r + '%'; stat2l.textContent = 'CVR';
      stat3.textContent = fmt(aov); stat3l.textContent = 'Avg order value';
      verdict.textContent = '💰 ' + convs + ' conversions × $' + aov.toLocaleString() + ' = ' + fmt(revenue) + '/month';
    }
    result.classList.add('visible');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
})();
</script>
