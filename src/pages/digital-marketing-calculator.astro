---
import Base from '../layouts/Base.astro';
import FAQ from '../components/FAQ.astro';

const slug        = 'digital-marketing-calculator';
const title       = 'Digital Marketing Calculator — CPM, CPC, CTR, ROAS, CPA (2026)';
const description = 'Digital marketing calculator: compute CPM, CPC, CTR, ROAS, and CPA from one set of campaign inputs. All 5 metrics at once. Free, no signup required.';

const faqItems = [
  { q: 'What is CPM in digital marketing?', a: 'CPM (Cost Per Mille) is the cost to show your ad 1,000 times. Formula: CPM = (Ad Spend ÷ Impressions) × 1,000. Average CPM varies: Google Display ~$2, Facebook ~$8, LinkedIn ~$35.' },
  { q: 'What is a good ROAS?', a: 'A ROAS of 4:1 ($4 revenue per $1 spent) is a common break-even benchmark. Most eCommerce businesses target 4–8× ROAS. High-margin products can be profitable at 3×; low-margin at 6×+.' },
  { q: 'What is CPA in marketing?', a: 'CPA (Cost Per Acquisition) is how much you spend to acquire one customer. Formula: CPA = Total Ad Spend ÷ Number of Conversions. Compare against your average order value to determine profitability.' },
  { q: 'What is CTR and what is a good click-through rate?', a: 'CTR (Click-Through Rate) = Clicks ÷ Impressions × 100. Average CTRs: Google Search 3–5%, Google Display 0.1%, Facebook 0.9%, LinkedIn 0.4%. Higher CTR indicates relevance and ad quality.' },
  { q: 'Is this calculator free?', a: 'Yes — completely free, no signup, no email required.' },
];

const webAppSchema = { "@type": "WebApplication", "name": title, "applicationCategory": "BusinessApplication", "operatingSystem": "Any", "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }, "creator": { "@id": "https://freemarketingcalculator.com/#org" }, "url": "https://freemarketingcalculator.com/digital-marketing-calculator/", "description": "A multi-metric digital marketing calculator that computes CPM, CPC, CTR, ROAS, and CPA simultaneously from a single set of campaign inputs.", "featureList": ["CPM, CPC, CTR, ROAS, CPA", "All metrics from one input", "No signup required"] };
const faqSchema = { "@type": "FAQPage", "mainEntity": faqItems.map(i => ({ "@type": "Question", "name": i.q, "acceptedAnswer": { "@type": "Answer", "text": i.a } })) };
const breadcrumbSchema = { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freemarketingcalculator.com/" }, { "@type": "ListItem", "position": 2, "name": "Digital Marketing Calculator", "item": "https://freemarketingcalculator.com/digital-marketing-calculator/" }] };
---

<Base title={title} description={description} slug={slug} schema={[webAppSchema, faqSchema, breadcrumbSchema]}>
  <section class="page-hero" aria-labelledby="page-h1">
    <div class="container">
      <p class="eyebrow">Free Marketing Tool</p>
      <h1 id="page-h1">Digital Marketing Calculator</h1>
      <p class="citation">A multi-metric digital marketing calculator that computes CPM, CPC, CTR, ROAS, and CPA simultaneously from a single set of campaign inputs — no switching between tools.</p>
      <div class="meta-badges">
        <span class="badge">✓ CPM, CPC, CTR, ROAS, CPA</span>
        <span class="badge">✓ All metrics at once</span>
        <span class="badge">✓ No signup</span>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="calc-card">
      <div class="calc-card__header">
        <div class="calc-card__header-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="12" y2="18"/></svg>
        </div>
        <div><div class="calc-card__title">Digital Marketing Calculator</div><div class="calc-card__subtitle">Enter campaign data — get all 5 metrics instantly</div></div>
      </div>
      <div class="calc-card__body">
        <div class="field-group">
          <div class="field"><label for="dm-spend">Total Ad Spend ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="dm-spend" class="has-prefix" placeholder="e.g. 5000" min="0"/></div></div>
          <div class="field"><label for="dm-impressions">Impressions</label><input type="number" id="dm-impressions" placeholder="e.g. 500000" min="0"/></div>
          <div class="field"><label for="dm-clicks">Clicks</label><input type="number" id="dm-clicks" placeholder="e.g. 4500" min="0"/></div>
          <div class="field"><label for="dm-conversions">Conversions</label><input type="number" id="dm-conversions" placeholder="e.g. 90" min="0"/></div>
          <div class="field"><label for="dm-revenue">Revenue Generated ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="dm-revenue" class="has-prefix" placeholder="e.g. 22000" min="0"/></div></div>
        </div>
        <button class="btn-calc" id="dm-calc-btn" type="button">Calculate All Metrics</button>
        <div class="result-panel" id="dm-result" aria-live="polite">
          <div class="result-panel__label">Your Campaign Metrics</div>
          <div class="result-panel__primary" id="dm-roas">0×</div>
          <div class="result-panel__grid">
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="dm-cpm">$0</span><span class="result-panel__stat-label">CPM</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="dm-cpc">$0</span><span class="result-panel__stat-label">CPC</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="dm-ctr">0%</span><span class="result-panel__stat-label">CTR</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="dm-cpa">$0</span><span class="result-panel__stat-label">CPA</span></div>
          </div>
          <div class="result-verdict" id="dm-verdict"></div>
        </div>
      </div>
    </div>

    <div class="definition-box">
      <div class="definition-box__label">Formulas (plain text — all 5)</div>
      <p>
        <strong>CPM</strong> = (Ad Spend ÷ Impressions) × 1,000<br/>
        <strong>CPC</strong> = Ad Spend ÷ Clicks<br/>
        <strong>CTR</strong> = (Clicks ÷ Impressions) × 100<br/>
        <strong>CPA</strong> = Ad Spend ÷ Conversions<br/>
        <strong>ROAS</strong> = Revenue ÷ Ad Spend
      </p>
    </div>


    <!-- TASK 23: Related guide link -->
    <div style="background: var(--teal-faint); border: 1.5px solid rgba(0,196,179,.25); border-radius: var(--radius-lg); padding: var(--space-4) var(--space-6); margin: var(--space-6) 0; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap: var(--space-3);">
      <p style="color: var(--navy); font-weight: 600; margin:0; font-size: var(--text-sm);">📖 CPM, CPC, CTR, ROAS, CPA Explained — Full metrics guide →</p>
      <a href="/blog/digital-marketing-metrics-guide/" style="background: var(--teal); color: var(--navy); font-weight: 700; font-size: var(--text-sm); padding: var(--space-2) var(--space-5); border-radius: var(--radius); text-decoration:none; white-space:nowrap;">Read now →</a>
    </div>


    <!-- TASK 25: How to use this calculator -->
    <div class="definition-box" style="margin-top: var(--space-8);">
      <div class="definition-box__label">How to Use This Digital Marketing Calculator</div>
      <p style="white-space: pre-line; line-height: 1.9;">1. Enter your total ad spend for the campaign period. 2. Enter impressions, clicks, conversions, and revenue generated. 3. You can leave any field blank — the calculator will compute whichever metrics have enough data. 4. Click Calculate All Metrics to see CPM, CPC, CTR, CPA, and ROAS simultaneously.</p>
      <div class="formula-example" style="margin-top: var(--space-3);">
        <strong>Example:</strong> Example: $5,000 spend, 500,000 impressions, 4,500 clicks, 90 conversions, $22,000 revenue → CPM $10 | CPC $1.11 | CTR 0.9% | CPA $55.56 | ROAS 4.4×.
      </div>
    </div>

    <FAQ items={faqItems} />
  </div>
</Base>

<script>
(function(){
  'use strict';
  const btn = document.getElementById('dm-calc-btn');
  const result = document.getElementById('dm-result');
  if (!btn) return;
  btn.addEventListener('click', () => {
    const spend  = parseFloat(document.getElementById('dm-spend').value) || 0;
    const imps   = parseFloat(document.getElementById('dm-impressions').value) || 0;
    const clicks = parseFloat(document.getElementById('dm-clicks').value) || 0;
    const convs  = parseFloat(document.getElementById('dm-conversions').value) || 0;
    const rev    = parseFloat(document.getElementById('dm-revenue').value) || 0;
    if (!spend) return;
    const cpm  = imps  > 0 ? (spend / imps) * 1000 : 0;
    const cpc  = clicks > 0 ? spend / clicks : 0;
    const ctr  = imps  > 0 ? (clicks / imps) * 100 : 0;
    const cpa  = convs > 0 ? spend / convs : 0;
    const roas = spend > 0 ? rev / spend : 0;
    document.getElementById('dm-roas').textContent    = roas.toFixed(2) + '×';
    document.getElementById('dm-cpm').textContent     = '$' + cpm.toFixed(2);
    document.getElementById('dm-cpc').textContent     = '$' + cpc.toFixed(2);
    document.getElementById('dm-ctr').textContent     = ctr.toFixed(2) + '%';
    document.getElementById('dm-cpa').textContent     = '$' + cpa.toFixed(2);
    const roasVerdict = roas >= 4 ? '✅ ROAS ≥ 4× — profitable for most business models' : roas >= 2 ? '🟡 ROAS 2–4× — marginal; review costs and targeting' : '⚠️ ROAS < 2× — campaign likely unprofitable; pause and optimise';
    document.getElementById('dm-verdict').textContent = roasVerdict;
    result.classList.add('visible');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
})();
</script>
