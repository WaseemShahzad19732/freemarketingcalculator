---
import Base from '../layouts/Base.astro';
import FAQ from '../components/FAQ.astro';

const slug        = 'social-media-budget-calculator';
const title       = 'Social Media Budget Calculator — By Platform and Goal 2026';
const description = 'Calculate your social media marketing budget by platform and campaign goal. Benchmarks for paid and organic across Facebook, Instagram, TikTok, and LinkedIn.';

const faqItems = [
  { q: 'How do I use this calculator?', a: 'Enter your numbers in the fields above and click Calculate. Results appear instantly with no signup or email required.' },
  { q: 'Is this calculator free?', a: 'Yes, completely free with no subscription, email gate, or hidden costs.' },
  { q: 'How accurate are the benchmarks?', a: 'Benchmarks are compiled from public industry research (Gartner, HubSpot, Salesforce). They represent industry medians — individual results vary.' },
];

const webAppSchema = {
  "@type": "WebApplication",
  "name": "Social Media Budget Calculator — By Platform and Goal 2026",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "creator": { "@id": "https://freemarketingcalculator.com/#org" },
  "url": "https://freemarketingcalculator.com/social-media-budget-calculator/",
  "description": "Recommends paid and organic social media budget by platform and campaign goal, with CPM benchmarks for Facebook, Instagram, TikTok, LinkedIn, and Pinterest.",
  "featureList": ["Free to use", "No signup required", "Instant results"]
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question", "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freemarketingcalculator.com/" },
    { "@type": "ListItem", "position": 2, "name": "Social Media Budget Calculator — By Platform and Goal 2026", "item": "https://freemarketingcalculator.com/social-media-budget-calculator/" }
  ]
};
---

<Base title={title} description={description} slug={slug} schema={[webAppSchema, faqSchema, breadcrumbSchema]}>

  <section class="page-hero" aria-labelledby="page-h1">
    <div class="container">
      <p class="eyebrow">Free Marketing Tool</p>
      <h1 id="page-h1">{title}</h1>
      <p class="citation">Recommends paid and organic social media budget by platform and campaign goal, with CPM benchmarks for Facebook, Instagram, TikTok, LinkedIn, and Pinterest.</p>
      <div class="meta-badges">
        <span class="badge">✓ Free forever</span>
        <span class="badge">✓ No signup required</span>
        <span class="badge">✓ Updated July 2026</span>
      </div>
    </div>
  </section>

  <div class="container">

    <div class="calc-card" aria-label="Calculator tool">
      <div class="calc-card__header">
        <div>
          <div class="calc-card__title">{title}</div>
          <div class="calc-card__subtitle">Full calculator — enter your numbers for instant results</div>
        </div>
      </div>
      <div class="calc-card__body">
        <p style="color: var(--text-mid); font-size: var(--text-sm);">
          Full calculator widget goes here. See the ROI and Budget calculators for the complete implementation pattern.
          <a href="/marketing-roi-calculator/">View the ROI Calculator as a reference →</a>
        </p>
      </div>
    </div>

    <section class="prose content-section">
      <h2>About This Calculator</h2>
      <p>Recommends paid and organic social media budget by platform and campaign goal, with CPM benchmarks for Facebook, Instagram, TikTok, LinkedIn, and Pinterest.</p>
    </section>

    <FAQ items={faqItems} />

  </div>
</Base>
