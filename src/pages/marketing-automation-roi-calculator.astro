---
import Base from '../layouts/Base.astro';
import FAQ from '../components/FAQ.astro';

const slug        = 'marketing-automation-roi-calculator';
const title       = 'Marketing Automation ROI Calculator — Free B2B Tool 2026';
const description = 'Calculate the ROI of marketing automation for B2B. Compares manual vs automated costs, lead volume lift, and time savings. Free, no signup required.';

const faqItems = [
  { q: 'What is the ROI of marketing automation?', a: 'Marketing automation typically delivers 14.5% increase in sales productivity and a 12.2% reduction in marketing overhead (Salesforce). Companies report 451% increase in qualified leads and 34% reduction in cost per lead within 12 months of adoption.' },
  { q: 'How long does marketing automation take to pay off?', a: 'Most B2B companies break even on marketing automation within 6–12 months. Payback period depends on platform cost, current team size, and how aggressively workflows are built. Companies with 5+ marketing staff typically see ROI fastest.' },
  { q: 'Is marketing automation worth it for small businesses?', a: 'For businesses with fewer than 3 marketing staff, the ROI is often marginal in year one. A better entry point is affordable tools like Brevo or Mailchimp automation at $25–$65/month before committing to HubSpot or Marketo at $800–$3,000/month.' },
  { q: 'What should I include in marketing automation ROI calculation?', a: 'Include: (1) time saved on manual tasks × hourly cost, (2) lead volume lift × conversion rate × deal value, (3) reduced cost per lead, minus (4) platform subscription cost and (5) implementation and training time.' },
  { q: 'Is this calculator free?', a: 'Yes — completely free, no signup, no email required.' },
];

const webAppSchema = { "@type": "WebApplication", "name": title, "applicationCategory": "BusinessApplication", "operatingSystem": "Any", "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }, "creator": { "@id": "https://freemarketingcalculator.com/#org" }, "url": "https://freemarketingcalculator.com/marketing-automation-roi-calculator/", "description": "Calculates B2B marketing automation ROI from weekly hours saved, hourly cost, platform subscription price, and expected lead lift percentage with break-even timeline.", "featureList": ["Time savings calculation", "Lead lift ROI", "Break-even timeline", "Platform cost comparison"] };
const faqSchema = { "@type": "FAQPage", "mainEntity": faqItems.map(i => ({ "@type": "Question", "name": i.q, "acceptedAnswer": { "@type": "Answer", "text": i.a } })) };
const breadcrumbSchema = { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freemarketingcalculator.com/" }, { "@type": "ListItem", "position": 2, "name": "Marketing Automation ROI Calculator", "item": "https://freemarketingcalculator.com/marketing-automation-roi-calculator/" }] };
---

<Base title={title} description={description} slug={slug} schema={[webAppSchema, faqSchema, breadcrumbSchema]}>
  <section class="page-hero" aria-labelledby="page-h1">
    <div class="container">
      <p class="eyebrow">Free Marketing Tool</p>
      <h1 id="page-h1">Marketing Automation ROI Calculator</h1>
      <p class="citation">Calculates B2B marketing automation ROI from weekly hours saved, hourly staff cost, platform subscription cost, and expected lead lift — with break-even timeline and annual savings projection.</p>
      <div class="meta-badges">
        <span class="badge">✓ Time + lead savings</span>
        <span class="badge">✓ Break-even timeline</span>
        <span class="badge">✓ No signup</span>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="calc-card">
      <div class="calc-card__header">
        <div class="calc-card__header-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
        </div>
        <div><div class="calc-card__title">Marketing Automation ROI Calculator</div><div class="calc-card__subtitle">Enter your current costs and expected improvements</div></div>
      </div>
      <div class="calc-card__body">
        <div class="field-group">
          <div class="field"><label for="ma-hours">Hours/week spent on manual marketing tasks</label><input type="number" id="ma-hours" placeholder="e.g. 15" min="0" step="0.5"/><p class="hint">Email scheduling, list management, follow-up sequences, reporting</p></div>
          <div class="field"><label for="ma-hourly">Average hourly cost of marketing staff ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="ma-hourly" class="has-prefix" placeholder="e.g. 45" min="0"/></div><p class="hint">Include salary, benefits, and overhead (typically 1.3–1.5× base salary)</p></div>
          <div class="field"><label for="ma-platform">Monthly platform cost ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="ma-platform" class="has-prefix" placeholder="e.g. 800" min="0"/></div></div>
          <div class="field"><label for="ma-leads">Current monthly leads</label><input type="number" id="ma-leads" placeholder="e.g. 200" min="0"/></div>
          <div class="field"><label for="ma-lift">Expected lead volume lift from automation (%)</label><div class="input-wrap"><input type="number" id="ma-lift" class="has-suffix" placeholder="e.g. 30" min="0" max="200"/><span class="input-suffix">%</span></div><p class="hint">Industry average is 25–45% increase in qualified leads</p></div>
          <div class="field"><label for="ma-deal">Average deal / customer value ($)</label><div class="input-wrap"><span class="input-prefix">$</span><input type="number" id="ma-deal" class="has-prefix" placeholder="e.g. 2500" min="0"/></div></div>
          <div class="field"><label for="ma-close">Lead-to-customer close rate (%)</label><div class="input-wrap"><input type="number" id="ma-close" class="has-suffix" placeholder="e.g. 5" min="0" max="100" step="0.5"/><span class="input-suffix">%</span></div></div>
        </div>
        <button class="btn-calc" id="ma-calc-btn" type="button">Calculate Automation ROI</button>
        <div class="result-panel" id="ma-result" aria-live="polite">
          <div class="result-panel__label">Marketing Automation ROI</div>
          <div class="result-panel__primary" id="ma-primary">0%</div>
          <div class="result-panel__grid">
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="ma-annual-save">$0</span><span class="result-panel__stat-label">Annual savings</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="ma-revenue-lift">$0</span><span class="result-panel__stat-label">Revenue lift/yr</span></div>
            <div class="result-panel__stat"><span class="result-panel__stat-value" id="ma-breakeven">0 mo</span><span class="result-panel__stat-label">Break-even</span></div>
          </div>
          <div class="result-verdict" id="ma-verdict"></div>
        </div>
      </div>
    </div>

    <div class="formula-box">
      <p class="formula-title">Formula</p>
      <p class="formula-text">Annual Time Savings = Hours/week × 52 × Hourly Cost<br/>Revenue Lift = Additional Leads × Close Rate × Deal Value<br/>ROI = (Savings + Revenue Lift − Platform Cost) ÷ Platform Cost × 100</p>
    </div>

    <FAQ items={faqItems} />
  </div>
</Base>

<script>
(function(){
  'use strict';
  const btn = document.getElementById('ma-calc-btn');
  const result = document.getElementById('ma-result');
  if (!btn) return;
  function fmt(n: number) { return n >= 1000000 ? '$' + (n/1000000).toFixed(2) + 'M' : '$' + Math.round(n).toLocaleString(); }
  btn.addEventListener('click', () => {
    const hours    = parseFloat((document.getElementById('ma-hours') as HTMLInputElement).value) || 0;
    const hourly   = parseFloat((document.getElementById('ma-hourly') as HTMLInputElement).value) || 0;
    const platform = parseFloat((document.getElementById('ma-platform') as HTMLInputElement).value) || 1;
    const leads    = parseFloat((document.getElementById('ma-leads') as HTMLInputElement).value) || 0;
    const lift     = parseFloat((document.getElementById('ma-lift') as HTMLInputElement).value) / 100 || 0;
    const deal     = parseFloat((document.getElementById('ma-deal') as HTMLInputElement).value) || 0;
    const close    = parseFloat((document.getElementById('ma-close') as HTMLInputElement).value) / 100 || 0;
    if (!hourly && !leads) return;
    const annualTimeSave   = hours * 52 * hourly;
    const additionalLeads  = leads * lift * 12;
    const revenueLift      = additionalLeads * close * deal;
    const annualPlatform   = platform * 12;
    const netBenefit       = annualTimeSave + revenueLift - annualPlatform;
    const roi              = platform > 0 ? (netBenefit / annualPlatform) * 100 : 0;
    const breakEven        = netBenefit > 0 ? Math.ceil(annualPlatform / ((annualTimeSave + revenueLift) / 12)) : 999;
    document.getElementById('ma-primary').textContent      = roi.toFixed(0) + '%';
    document.getElementById('ma-annual-save').textContent  = fmt(annualTimeSave);
    document.getElementById('ma-revenue-lift').textContent = fmt(revenueLift);
    document.getElementById('ma-breakeven').textContent    = breakEven < 999 ? breakEven + ' months' : 'No ROI';
    document.getElementById('ma-verdict').textContent =
      roi > 300 ? '🚀 Excellent ROI — automation will pay for itself in under ' + breakEven + ' months' :
      roi > 100 ? '✅ Positive ROI — strong case for automation investment' :
      roi > 0   ? '🟡 Marginal ROI — consider a lower-cost platform or more aggressive workflows' :
                  '⚠️ Negative ROI — reduce platform cost or increase hours/leads input';
    result.classList.add('visible');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
})();
</script>
