---
import Base from '../layouts/Base.astro';

const slug        = '';
const title       = 'Free Marketing Calculators — ROI, Budget, Salary & More (2026)';
const description = 'Free marketing calculators for ROI, budget planning, conversion rate, email ROI, salary benchmarks, and campaign metrics. Instant results, no signup required.';

// ROI & Performance
const roiTools = [
  { href: '/marketing-roi-calculator/', name: 'Marketing ROI Calculator',
    desc: 'Computes basic ROMI and gross-profit ROI with COGS. Channel presets for email, SEO, paid, content, and social.', cta: 'Calculate ROI →', badge: 'Most popular' },
  { href: '/email-marketing-roi-calculator/', name: 'Email Marketing ROI Calculator',
    desc: 'Computes email ROMI from list size, open rate, click rate, conversion rate, and monthly platform cost.', cta: 'Calculate Email ROI →', badge: '' },
  { href: '/marketing-automation-roi-calculator/', name: 'Marketing Automation ROI',
    desc: 'Calculates ROI of marketing automation from time savings, lead lift %, and platform cost. Built for B2B.', cta: 'Calculate Automation ROI →', badge: '' },
  { href: '/conversion-rate-calculator/', name: 'Conversion Rate Calculator',
    desc: 'Calculates CVR, reverse-computes traffic needed for a revenue goal, and benchmarks your rate by channel.', cta: 'Calculate CVR →', badge: '' },
];

// Budget & Planning
const budgetTools = [
  { href: '/marketing-budget-calculator/', name: 'Marketing Budget Calculator',
    desc: 'Recommends marketing budget from annual revenue and industry, with 9-sector benchmarks and Google Sheets download.', cta: 'Calculate Budget →', badge: '' },
  { href: '/social-media-budget-calculator/', name: 'Social Media Budget Calculator',
    desc: 'Recommends paid and organic social budget by platform and campaign goal, with CPM benchmarks.', cta: 'Calculate Social Budget →', badge: '' },
  { href: '/inbound-marketing-calculator/', name: 'Inbound Marketing Calculator',
    desc: 'Reverse-funnel calculator: enter a revenue goal and get the traffic, MQL, and lead targets needed.', cta: 'Plan Inbound →', badge: '' },
];

// Advertising Metrics
const adTools = [
  { href: '/digital-marketing-calculator/', name: 'Digital Marketing Calculator',
    desc: 'Computes CPM, CPC, CTR, ROAS, and CPA from a single set of campaign inputs — all metrics at once.', cta: 'Calculate Metrics →', badge: '' },
  { href: '/cpm-calculator/', name: 'CPM Calculator',
    desc: 'Calculate cost per thousand impressions, total ad spend, or total impressions. 2026 platform benchmarks.', cta: 'Calculate CPM →', badge: '' },
  { href: '/cpc-calculator/', name: 'CPC Calculator',
    desc: 'Calculate cost per click, total spend from clicks, or expected clicks from budget. Industry benchmarks.', cta: 'Calculate CPC →', badge: '' },
  { href: '/cpv-calculator/', name: 'CPV Calculator',
    desc: 'Calculate cost per view for YouTube, TikTok, and LinkedIn video campaigns. 2026 CPV benchmarks.', cta: 'Calculate CPV →', badge: '' },
];

// Career & Business
const careerTools = [
  { href: '/marketing-salary-calculator/', name: 'Marketing Salary Calculator',
    desc: 'Estimates marketing salary range by role, seniority, and US location. Covers managers, directors, CMOs.', cta: 'Check Salary →', badge: '' },
  { href: '/marketing-agency-valuation-calculator/', name: 'Agency Valuation Calculator',
    desc: 'Estimates a marketing agency market value using revenue multiples, EBITDA, and client retention rate.', cta: 'Value Your Agency →', badge: '' },
];

const websiteSchema = {
  "@type": "WebPage",
  "name": "Free Marketing Calculators",
  "url": "https://freemarketingcalculator.com/",
  "description": "Free marketing calculators for ROI, budget, salary, conversion rate, email ROI, and more.",
  "publisher": { "@id": "https://freemarketingcalculator.com/#org" }
};
---

<Base title={title} description={description} slug={slug} schema={[websiteSchema]}>
  <section class="page-hero" style="padding-bottom: var(--space-12);" aria-labelledby="home-h1">
    <div class="container">
      <p class="eyebrow">Free Marketing Tools — 2026</p>
      <h1 id="home-h1">Marketing Calculators</h1>
      <p class="citation">13 free marketing calculators for ROI, budget planning, conversion rates, email performance, salary benchmarks, CPM, CPC, and more. Instant results. No signup. No email gate.</p>
      <div class="meta-badges">
        <span class="badge">✓ 13 calculators</span>
        <span class="badge">✓ Free forever</span>
        <span class="badge">✓ Updated July 2026</span>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- H2: ROI & Performance -->
    <section aria-labelledby="roi-section">
      <h2 id="roi-section" class="home-section-heading">ROI & Performance Calculators</h2>
      <ul class="tool-grid" style="list-style:none; padding:0; margin:0;">
        {roiTools.map(tool => (
          <li>
            <a href={tool.href} class="tool-card">
              <div class="tool-card__name">
                {tool.name}
                {tool.badge && <span style="margin-left:0.5rem;font-size:10px;font-weight:700;background:var(--teal-faint);color:var(--teal-dark);padding:2px 8px;border-radius:100px;vertical-align:middle;">{tool.badge}</span>}
              </div>
              <p class="tool-card__desc">{tool.desc}</p>
              <span class="tool-card__cta">{tool.cta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- H2: Budget & Planning -->
    <section aria-labelledby="budget-section" style="margin-top: var(--space-10);">
      <h2 id="budget-section" class="home-section-heading">Budget & Planning Calculators</h2>
      <ul class="tool-grid" style="list-style:none; padding:0; margin:0;">
        {budgetTools.map(tool => (
          <li>
            <a href={tool.href} class="tool-card">
              <div class="tool-card__name">
                {tool.name}
                {tool.badge && <span style="margin-left:0.5rem;font-size:10px;font-weight:700;background:var(--teal-faint);color:var(--teal-dark);padding:2px 8px;border-radius:100px;vertical-align:middle;">{tool.badge}</span>}
              </div>
              <p class="tool-card__desc">{tool.desc}</p>
              <span class="tool-card__cta">{tool.cta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- H2: Advertising Metrics -->
    <section aria-labelledby="ads-section" style="margin-top: var(--space-10);">
      <h2 id="ads-section" class="home-section-heading">Advertising Metric Calculators</h2>
      <ul class="tool-grid" style="list-style:none; padding:0; margin:0;">
        {adTools.map(tool => (
          <li>
            <a href={tool.href} class="tool-card">
              <div class="tool-card__name">
                {tool.name}
                {tool.badge && <span style="margin-left:0.5rem;font-size:10px;font-weight:700;background:var(--teal-faint);color:var(--teal-dark);padding:2px 8px;border-radius:100px;vertical-align:middle;">{tool.badge}</span>}
              </div>
              <p class="tool-card__desc">{tool.desc}</p>
              <span class="tool-card__cta">{tool.cta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- H2: Career & Business -->
    <section aria-labelledby="career-section" style="margin-top: var(--space-10); margin-bottom: var(--space-12);">
      <h2 id="career-section" class="home-section-heading">Career & Business Calculators</h2>
      <ul class="tool-grid" style="list-style:none; padding:0; margin:0;">
        {careerTools.map(tool => (
          <li>
            <a href={tool.href} class="tool-card">
              <div class="tool-card__name">
                {tool.name}
                {tool.badge && <span style="margin-left:0.5rem;font-size:10px;font-weight:700;background:var(--teal-faint);color:var(--teal-dark);padding:2px 8px;border-radius:100px;vertical-align:middle;">{tool.badge}</span>}
              </div>
              <p class="tool-card__desc">{tool.desc}</p>
              <span class="tool-card__cta">{tool.cta}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </div>
</Base>

<style>
  .home-section-heading {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--border);
  }
</style>
