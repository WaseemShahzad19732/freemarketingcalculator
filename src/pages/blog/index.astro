---
import Base from '../../layouts/Base.astro';

const slug = 'blog';
const title = 'Marketing Resources & Guides — Free Marketing Calculators';
const description = 'Marketing benchmarks, guides, and data for marketers. Industry research on budgets, ROI, salaries, and campaign performance — updated 2026.';

const posts = [
  {
    slug: '/marketing-budget-benchmarks/',
    title: 'Marketing Budget Benchmarks by Industry — 2026 Data',
    description: 'How much should you spend on marketing? Benchmarks for 9 industries from Gartner, Deloitte, and HubSpot CMO surveys.',
    date: 'July 6, 2026',
    category: 'Research & Data',
    readTime: '5 min read',
    featured: true,
  },
  {
    slug: '/blog/what-is-a-good-marketing-roi/',
    title: 'What Is a Good Marketing ROI? Benchmarks by Channel (2026)',
    description: 'Email averages 4200%, SEO 275%, paid search 200%. A complete guide to marketing ROI benchmarks with the formulas behind them.',
    date: 'July 7, 2026',
    category: 'ROI & Performance',
    readTime: '6 min read',
    featured: false,
  },
  {
    slug: '/blog/marketing-budget-small-business/',
    title: 'How to Set a Marketing Budget for a Small Business',
    description: 'A practical step-by-step guide for businesses under $5M revenue — including the percentage method, objective-based budgeting, and common mistakes.',
    date: 'Coming soon',
    category: 'Budget Planning',
    readTime: '7 min read',
    featured: false,
  },
  {
    slug: '/blog/digital-marketing-metrics-guide/',
    title: 'The Complete Guide to Digital Marketing Metrics (CPM, CPC, CTR, ROAS, CPA)',
    description: 'Every metric explained: what it means, the formula, what good looks like, and when to use it. With 2026 industry benchmarks.',
    date: 'Coming soon',
    category: 'Metrics & Analytics',
    readTime: '8 min read',
    featured: false,
  },
  {
    slug: '/blog/email-marketing-roi-benchmarks/',
    title: 'Email Marketing ROI Benchmarks — Is $36:$1 Still Accurate in 2026?',
    description: 'The famous email ROI stat examined. Where it comes from, what it means for your campaigns, and realistic expectations by list size and industry.',
    date: 'Coming soon',
    category: 'Email Marketing',
    readTime: '5 min read',
    featured: false,
  },
  {
    slug: '/blog/marketing-salary-guide/',
    title: 'Marketing Salaries in 2026 — Complete Guide by Role and City',
    description: 'Average salaries for marketing managers, directors, CMOs, SEO specialists, and paid media managers — with city-by-city breakdown.',
    date: 'Coming soon',
    category: 'Career & Salary',
    readTime: '6 min read',
    featured: false,
  },
];

const schema = {
  "@type": "Blog",
  "name": "Free Marketing Calculators — Blog",
  "url": "https://freemarketingcalculator.com/blog/",
  "description": description,
  "publisher": { "@id": "https://freemarketingcalculator.com/#org" }
};
---

<Base title={title} description={description} slug={slug} schema={[schema]}>

  <section class="page-hero" aria-labelledby="blog-h1">
    <div class="container">
      <p class="eyebrow">Marketing Resources</p>
      <h1 id="blog-h1">Guides & Benchmarks</h1>
      <p class="citation">
        Marketing benchmarks, data, and practical guides for marketers who want
        accurate numbers without the paywall. All sourced, all dated, all free.
      </p>
    </div>
  </section>

  <div class="container" style="padding: var(--space-12) var(--space-6);">

    <!-- Featured post -->
    {posts.filter(p => p.featured).map(post => (
      <article class="featured-post" aria-label={`Featured: ${post.title}`}>
        <div class="featured-post__inner">
          <div class="post-meta">
            <span class="post-category">{post.category}</span>
            <span class="post-date">{post.date}</span>
            <span class="post-read">{post.readTime}</span>
          </div>
          <h2 class="featured-post__title">
            <a href={post.slug}>{post.title}</a>
          </h2>
          <p class="featured-post__desc">{post.description}</p>
          <a href={post.slug} class="btn-read-more">Read article →</a>
        </div>
        <div class="featured-post__badge">Featured</div>
      </article>
    ))}

    <!-- Post grid -->
    <h2 class="section-heading" style="margin-top: var(--space-12);">All Articles</h2>
    <div class="post-grid">
      {posts.map(post => (
        <article class={`post-card ${post.featured ? 'post-card--featured' : ''}`}>
          <div class="post-card__meta">
            <span class="post-category">{post.category}</span>
            {post.date !== 'Coming soon'
              ? <span class="post-date">{post.date}</span>
              : <span class="post-coming">Coming soon</span>
            }
          </div>
          <h3 class="post-card__title">
            {post.date !== 'Coming soon'
              ? <a href={post.slug}>{post.title}</a>
              : post.title
            }
          </h3>
          <p class="post-card__desc">{post.description}</p>
          {post.date !== 'Coming soon' && (
            <a href={post.slug} class="post-card__cta">{post.readTime} →</a>
          )}
        </article>
      ))}
    </div>

    <!-- Tools CTA -->
    <div class="blog-tools-cta">
      <h2>Need a calculator?</h2>
      <p>All the metrics mentioned in our articles have a free calculator to go with them.</p>
      <a href="/" class="btn-calc" style="display:inline-block; width:auto; padding: var(--space-3) var(--space-8);">
        View All Calculators →
      </a>
    </div>

  </div>
</Base>

<style>
  /* Featured post */
  .featured-post {
    position: relative;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    color: var(--white);
    margin-bottom: var(--space-8);
    overflow: hidden;
  }

  .featured-post__badge {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: var(--teal);
    color: var(--navy);
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .1em;
    padding: var(--space-1) var(--space-3);
    border-radius: 100px;
  }

  .featured-post__title {
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: var(--space-3) 0;
  }

  .featured-post__title a {
    color: var(--white);
    text-decoration: none;
  }

  .featured-post__title a:hover { color: var(--teal); }

  .featured-post__desc {
    color: rgba(255,255,255,.75);
    font-size: var(--text-base);
    line-height: 1.65;
    max-width: 640px;
    margin-bottom: var(--space-6);
  }

  .btn-read-more {
    display: inline-flex;
    align-items: center;
    background: var(--teal);
    color: var(--navy);
    font-weight: 700;
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius);
    text-decoration: none;
    transition: background .15s;
  }

  .btn-read-more:hover { background: var(--teal-dark); color: var(--white); }

  /* Post meta */
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
  }

  .post-category {
    background: rgba(0,196,179,.15);
    color: var(--teal);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: 2px var(--space-3);
    border-radius: 100px;
  }

  .featured-post .post-category {
    background: rgba(255,255,255,.15);
    color: var(--teal);
  }

  .post-date, .post-read {
    font-size: var(--text-xs);
    color: rgba(255,255,255,.5);
  }

  /* Post grid */
  .section-heading {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color .15s, box-shadow .15s;
  }

  .post-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow);
  }

  .post-card--featured {
    border-color: var(--teal);
    background: var(--teal-faint);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .post-card__meta .post-category {
    background: var(--teal-faint);
    color: var(--teal-dark);
  }

  .post-card__meta .post-date {
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .post-coming {
    font-size: var(--text-xs);
    color: var(--text-light);
    font-style: italic;
  }

  .post-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .post-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .post-card__title a:hover { color: var(--teal-dark); }

  .post-card__desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: 1.6;
    flex: 1;
  }

  .post-card__cta {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--teal-dark);
    text-decoration: none;
    margin-top: auto;
  }

  .post-card__cta:hover { color: var(--navy); }

  /* Tools CTA */
  .blog-tools-cta {
    margin-top: var(--space-16);
    background: var(--off-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-align: center;
  }

  .blog-tools-cta h2 {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--navy);
    margin-bottom: var(--space-3);
  }

  .blog-tools-cta p {
    color: var(--text-mid);
    margin-bottom: var(--space-6);
  }
</style>
